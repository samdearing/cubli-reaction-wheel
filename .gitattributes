# Normalize line endings for text so desktop (Windows) and laptop don't churn diffs
* text=auto

# Treat these as binary — never try to line-merge or EOL-convert them
*.sldprt   binary
*.sldasm   binary
*.slddrw   binary
*.f3d      binary
*.step     binary
*.stp      binary
*.stl      binary
*.3mf      binary
*.png      binary
*.jpg      binary
*.pdf      binary
*.hex      binary

# --- OPTIONAL: Git LFS for large CAD/media ---
# Uncomment these AFTER running `git lfs install` if the repo gets heavy.
